# Solana trading mode
SOLANA_NETWORK=mainnet
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=
JUPITER_API_KEY=

# Risk controls
MAX_POSITION_SOL=0.1
MAX_DAILY_LOSS_SOL=1
MAX_OPEN_POSITIONS=1
DEFAULT_SLIPPAGE_BPS=100
TAKE_PROFIT_PCT=20
STOP_LOSS_PCT=10
TRAILING_STOP_PCT=8
TRADE_COOLDOWN_SECONDS=900
MIN_LIQUIDITY_USD=25000
MIN_VOLUME_USD=10000
MIN_MARKET_CAP_USD=50000
MAX_MARKET_CAP_USD=500000000
MIN_ORGANIC_SCORE=25
MAX_PRICE_IMPACT_PCT=5
MAX_VOLATILITY_PCT=40
MAX_HOLDER_CONCENTRATION_PCT=35
SOLANA_RESERVE_SOL=0.25

# Execution safety
ENABLE_PAPER_TRADING=true
ENABLE_SELLS=false
DRY_RUN=true
MAX_QUOTE_AGE_SLOTS=150

# Runner tuning
TRADING_POLL_INTERVAL_SECONDS=30
TRADING_MONITOR_INTERVAL_SECONDS=15
MAX_HOLD_DURATION_MINUTES=120
TOKEN_SCAN_LIMIT=20
TRADING_SCAN_CATEGORY=toptrending
TRADING_SCAN_INTERVAL=5m
ALLOW_DUPLICATE_ENTRIES=false
EMERGENCY_HALT=false
